{
  "name": "multimind-browser",
  "version": "0.1.0",
  "private": true,
  "description": "MultiMind Browser desktop shell",
  "main": "dist/main/index.js",
  "scripts": {
    "predev": "npm run build:main",
    "dev": "concurrently \"vite\" \"electron .\"",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build": "npm run build:renderer && npm run build:main",
    "package:mac": "npm run build && electron-builder --mac --universal",
    "package:win": "npm run build && electron-builder --win --x64",
    "package:all": "npm run build && electron-builder --mac --universal --win --x64"
  },
  "dependencies": {
    "electron-store": "^10.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vite": "^5.0.0"
  }
}
